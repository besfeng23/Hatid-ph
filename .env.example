# Hatid local development environment template
# Copy to .env.local for local development.
# Do not commit real secrets, private keys, service account JSON, provider credentials, or .env files.

# Firebase public client config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional public maps key for client-side map rendering only
NEXT_PUBLIC_MAPS_PUBLIC_KEY=

# Server-only variables for future backend/services
# Keep these out of browser bundles.
DATABASE_URL=
GOOGLE_CLOUD_PROJECT=
MAPS_SERVER_KEY=
GENKIT_API_KEY=

# Payment provider placeholders for future phases only
PAYMENT_PROVIDER=
PAYMENT_PROVIDER_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYOUT_PROVIDER_SECRET_KEY=

# SpeedCash placeholders for future due-diligence phase only
# Do not enable live SpeedCash payment/payout/remittance features until docs/11 and docs/26 requirements are satisfied.
SPEEDCASH_CLIENT_ID=
SPEEDCASH_CLIENT_SECRET=
SPEEDCASH_WEBHOOK_SECRET=
