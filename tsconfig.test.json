{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp-tests",
    "module": "commonjs",
    "target": "es2020",
    "moduleResolution": "node",
    "isolatedModules": false,
    "declaration": false,
    "sourceMap": false,
    "jsx": "react-jsx"
  },
  "include": [
    "src/lib/trips/**/*.ts",
    "tests/**/*.ts"
  ]
}
